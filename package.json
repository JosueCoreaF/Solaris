{
  "name": "solaris-hub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=partnercentral-backend",
    "dev:hub": "npm run dev --workspace=hub",
    "dev:hotel": "npm run dev --workspace=@solaris/hotel",
    "dev:gym": "npm run dev --workspace=@solaris/gym",
    "dev:restaurant": "npm run dev --workspace=@solaris/restaurant",
    "dev:portal": "npm run dev --workspace=@solaris/portal",
    "dev": "concurrently -c \"cyan,magenta,yellow,green\" \"npm run dev:backend\" \"npm run dev:hub\" \"npm run dev:hotel\" \"npm run dev:portal\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=partnercentral-backend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "postgres": "^3.4.9",
    "prompts": "^2.4.2"
  }
}
